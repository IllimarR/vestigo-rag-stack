# vestigo-rag-stack — infrastructure-level configuration
#
# Application-level settings (models, chunking, prompts, default collection)
# are NOT here — they live in ConfigProvider per docs/contracts.md §9.
# Everything below is a deployment-time decision read only by the composition
# root (main.py) and infrastructure adapters.

# --- Service ports --------------------------------------------------------
API_GATEWAY_PORT=8000
INGEST_API_PORT=8001
ADMIN_API_PORT=8002

# --- Infrastructure bindings (Phase 1: all placeholders) ------------------
# Values below document the shape of future choices; they are not read by
# any code yet because Phase 1 binds only placeholder implementations.
VECTOR_STORE_BACKEND=placeholder           # future: chromadb | pgvector
AUDIT_BACKEND=placeholder                  # future: file | database
CONFIG_BACKEND=placeholder                 # future: file | database
DOCUMENT_CONVERTER=placeholder             # future: pandoc | markitdown
SOURCE_CONNECTORS=placeholder              # future: filesystem,api_push,...

# --- File paths for file-based stubs (Phase 1/2) --------------------------
CONFIG_FILE_PATH=./config/config.yaml
AUDIT_LOG_FILE=./data/audit.log

# --- Database (Phase 4) ---------------------------------------------------
DATABASE_URL=

# --- Admin bootstrap (Phase 4) --------------------------------------------
ADMIN_INITIAL_USER=admin
ADMIN_INITIAL_PASSWORD=change-me
